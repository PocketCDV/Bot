#: app./asgi/api/v1/auth/router.py:111
msgid "message.login.success"
msgstr ""
"You're all set! Login successful.\n"
"\n"
"Tap the button below to go to the home page."

#: app./asgi/api/v1/auth/router.py:117
msgid "button.go_home"
msgstr "Go to Home Page"

#: app./bot/scenes/home.py:73
