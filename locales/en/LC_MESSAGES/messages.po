msgstr ""
"<b>{start_time} - {end_time} | {room}</b>\n"
"<i>{title}</i>"

#: app./bot/scenes/home.py:82
msgid "message.home"
msgstr ""
"<b>Here are your classes for today:</b>\n"
"\n"
"{classes}"

#: app./bot/scenes/login.py:58
msgid "message.login"
msgstr ""
"Your Wirtualna Uczelnia session has ended. To keep using PocketCDV, "
"please log in again using the button below — it only takes a moment."

#: app./bot/scenes/login.py:63 app./bot/scenes/start.py:67
msgid "button.login"
msgstr "Log in"

#: app./bot/scenes/start.py:34
msgid "message.greeting"
msgstr ""
"<b>Greetings, {first_name}!</b>\n"
"\n"
"Introducing <b>PocketCDV</b> - a Telegram bot for tracking class "
"schedules at Collegium da Vinci. Our goal is simplicity and "
"accessibility: wherever you are, just two taps and you'll instantly "
"know when your next class is.\n"
"\n"
"Many new features are already in development, and we'll keep you "
"updated on all the latest changes."

#: app./bot/scenes/start.py:38
msgid "button.proceed"
msgstr "Proceed"

#: app./bot/scenes/start.py:62
msgid "message.greeting.login"
msgstr ""
"To get started, we'll need your Wirtualna Uczelnia login credentials. "
"You can enter them by tapping the button below.\n"
"\n"
"A note on privacy: we never store any personal information - your name, "
"email address, or password are never saved. Your schedule is also never "
"stored and is fetched fresh every time you use the bot."
